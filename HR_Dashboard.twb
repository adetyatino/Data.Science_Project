      </column>
      <column aggregation='Sum' datatype='integer' name='[Age]' role='dimension' type='ordinal' />
      <column datatype='string' name='[Attrition]' role='dimension' type='nominal' />
      <column caption='Business Travel' datatype='string' name='[BusinessTravel]' role='dimension' type='nominal' />
      <column caption='Age Group ' datatype='string' name='[Calculation_0736455246139392]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt;= 25 THEN &quot;18-25&quot;&#13;&#10;ELSEIF [Age] &lt;= 35 THEN &quot;26-35&quot;&#13;&#10;ELSEIF [Age] &lt;= 45 THEN &quot;36-45&quot;&#13;&#10;ELSE &quot;46+&quot;&#13;&#10;END' />
      </column>
      <column caption='Attrition Flag' datatype='integer' datatype-customized='true' name='[Calculation_0810396391436288]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Attrition] = &quot;Yes&quot; OR [Attrition] = &quot;1&quot; OR [Attrition] = &quot;1.0&quot; THEN 1 &#13;&#10;ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='Attrition Rate' datatype='integer' datatype-customized='true' name='[Calculation_0810396391755777]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='INT(SUM([Calculation_0810396391436288]) / COUNTD([EmployeeId]))' />
      </column>
      <column caption='OverTime' datatype='integer' datatype-customized='true' name='[Calculation_0810396393844738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(SUM(IIF([OverTime] = &quot;Yes&quot;, 1, 0)) / COUNTD([EmployeeId]))' />
      </column>
      <column caption='WorkLifeBalance' datatype='string' name='[Calculation_0810396394295299]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [WorkLifeBalance] = 1 THEN &quot;Buruk (Poor)&quot;&#13;&#10;ELSEIF [WorkLifeBalance] = 2 THEN &quot;Cukup (Average)&quot;&#13;&#10;ELSEIF [WorkLifeBalance] = 3 THEN &quot;Baik (Good)&quot;&#13;&#10;ELSEIF [WorkLifeBalance] = 4 THEN &quot;Sangat Baik (Excellent)&quot;&#13;&#10;END' />
      </column>
      <column caption='DistanceFromHome' datatype='string' name='[Calculation_0810396394590212]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [DistanceFromHome] &lt;= 5 THEN &quot;Dekat (0-5 km)&quot;&#13;&#10;ELSEIF [DistanceFromHome] &lt;= 15 THEN &quot;Sedang (6-15 km)&quot;&#13;&#10;ELSE &quot;Jauh (&gt;15 km)&quot;&#13;&#10;END' />
      </column>
      <column caption='MonthlyIncome' datatype='string' name='[Calculation_0810396395433989]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [MonthlyIncome] &lt; 5000 THEN &quot;Low (&lt;5k)&quot;&#13;&#10;ELSEIF [MonthlyIncome] &lt;= 10000 THEN &quot;Medium (5k-10k)&quot;&#13;&#10;ELSE &quot;High (&gt;10k)&quot;&#13;&#10;END' />
      </column>
      <column caption='Salary Hike Category' datatype='string' name='[Calculation_0810396395892742]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PercentSalaryHike] &lt; 15 THEN &quot;Standard (&lt;15%)&quot;&#13;&#10;ELSE &quot;High (&gt;=15%)&quot;&#13;&#10;END' />
      </column>
      <column caption='Promotion Lag' datatype='string' name='[Calculation_0810396396273671]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [YearsSinceLastPromotion] &gt; 3 THEN &quot;Stagnan (&gt;3 Tahun)&quot;&#13;&#10;ELSE &quot;Wajar&quot;&#13;&#10;END' />
      </column>
      <column caption='Combined Satisfaction' datatype='real' name='[Calculation_0810396396441608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([EnvironmentSatisfaction] + [JobSatisfaction]) / 2' />
      </column>
      <column caption='Relationship &amp; Involvement Label' datatype='string' name='[Calculation_0810396396638217]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [RelationshipSatisfaction] &lt;= 2 THEN &quot;Low Engagement&quot;&#13;&#10;ELSE &quot;High Engagement&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_0810396396773386]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 25 THEN &quot;Gen Z&quot;&#13;&#10;ELSEIF [Age] &lt;= 40 THEN &quot;Millennials&quot;&#13;&#10;ELSE &quot;Gen X/Senior&quot;&#13;&#10;END' />
      </column>
      <column caption='Tenure' datatype='string' name='[Calculation_0810396396871691]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [YearsAtCompany] &lt;= 2 THEN &quot;0-2 Tahun (Junior)&quot;&#13;&#10;ELSEIF [YearsAtCompany] &lt;= 5 THEN &quot;3-5 Tahun (Associate)&quot;&#13;&#10;ELSE &quot; &gt;5 Tahun (Senior)&quot;&#13;&#10;END' />
      </column>
      <column caption='Attrition ' datatype='string' name='[Calculation_0810396411355149]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ZN(INT([Attrition])) = 1 THEN &quot;Resigned&quot; &#13;&#10;ELSE &quot;Active&quot; &#13;&#10;END' />
